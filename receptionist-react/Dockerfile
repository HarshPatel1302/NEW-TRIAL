FROM node:20-alpine AS build

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

# Required at build time (CRA inlines REACT_APP_* into the bundle).
ARG REACT_APP_GEMINI_API_KEY=""
ARG REACT_APP_RECEPTIONIST_API_URL="/api"
ARG REACT_APP_RECEPTIONIST_API_KEY=""
ARG REACT_APP_KIOSK_ID="greenscape-lobby-kiosk-1"

# Optional â€” same variables as `.env.example`; leave empty to use runtime defaults in code where applicable.
ARG REACT_APP_GATE_API_BASE_URL=""
ARG REACT_APP_GATE_LOGIN_API_URL=""
ARG REACT_APP_GATE_LOGIN_USERNAME=""
ARG REACT_APP_GATE_LOGIN_PASSWORD=""
ARG REACT_APP_WALKIN_COMPANY_ID=""
ARG REACT_APP_MEMBER_LIST_API_URL=""
ARG REACT_APP_VISITOR_LOG_API_URL=""
ARG REACT_APP_VISITOR_NOTIFICATION_API_URL=""
ARG REACT_APP_VISITOR_LOG_COMPANY_NAME=""
ARG REACT_APP_VISITOR_LOG_IN_GATE=""
ARG REACT_APP_VISITOR_PURPOSE_CATEGORY_ID=""
ARG REACT_APP_DELIVERY_PURPOSE_CATEGORY_ID=""
ARG REACT_APP_VISITOR_LOG_CARD_ID=""
ARG REACT_APP_DELIVERY_APPROVAL_API_URL=""
ARG REACT_APP_DELIVERY_APPROVAL_API_KEY=""
ARG REACT_APP_FORCE_LOBBY_DELIVERY_RESPONSE=""
ARG REACT_APP_AVATAR_MODEL_VERSION=""
ARG REACT_APP_VISITOR_SEARCH_URL=""
ARG REACT_APP_VR_IMAGE_UPLOAD_URL=""

# Production kiosk defaults (opt out with build-arg =0 / empty where applicable).
ARG REACT_APP_KIOSK_GATE_PROXY="1"
ARG REACT_APP_COMPACT_SYSTEM="1"
ARG REACT_APP_KIOSK_LOCAL_SPEECH="0"
ARG REACT_APP_DETERMINISTIC_LOCAL_PROMPTS="0"
ARG REACT_APP_PHOTO_CAPTURE_MODE="stable"
ARG REACT_APP_PHOTO_FACE_DETECT="1"

ENV REACT_APP_GEMINI_API_KEY=$REACT_APP_GEMINI_API_KEY
ENV REACT_APP_RECEPTIONIST_API_URL=$REACT_APP_RECEPTIONIST_API_URL
ENV REACT_APP_RECEPTIONIST_API_KEY=$REACT_APP_RECEPTIONIST_API_KEY
ENV REACT_APP_KIOSK_ID=$REACT_APP_KIOSK_ID
ENV REACT_APP_GATE_API_BASE_URL=$REACT_APP_GATE_API_BASE_URL
ENV REACT_APP_GATE_LOGIN_API_URL=$REACT_APP_GATE_LOGIN_API_URL
ENV REACT_APP_GATE_LOGIN_USERNAME=$REACT_APP_GATE_LOGIN_USERNAME
ENV REACT_APP_GATE_LOGIN_PASSWORD=$REACT_APP_GATE_LOGIN_PASSWORD
ENV REACT_APP_WALKIN_COMPANY_ID=$REACT_APP_WALKIN_COMPANY_ID
ENV REACT_APP_MEMBER_LIST_API_URL=$REACT_APP_MEMBER_LIST_API_URL
ENV REACT_APP_VISITOR_LOG_API_URL=$REACT_APP_VISITOR_LOG_API_URL
ENV REACT_APP_VISITOR_NOTIFICATION_API_URL=$REACT_APP_VISITOR_NOTIFICATION_API_URL
ENV REACT_APP_VISITOR_LOG_COMPANY_NAME=$REACT_APP_VISITOR_LOG_COMPANY_NAME
ENV REACT_APP_VISITOR_LOG_IN_GATE=$REACT_APP_VISITOR_LOG_IN_GATE
ENV REACT_APP_VISITOR_PURPOSE_CATEGORY_ID=$REACT_APP_VISITOR_PURPOSE_CATEGORY_ID
ENV REACT_APP_DELIVERY_PURPOSE_CATEGORY_ID=$REACT_APP_DELIVERY_PURPOSE_CATEGORY_ID
ENV REACT_APP_VISITOR_LOG_CARD_ID=$REACT_APP_VISITOR_LOG_CARD_ID
ENV REACT_APP_DELIVERY_APPROVAL_API_URL=$REACT_APP_DELIVERY_APPROVAL_API_URL
ENV REACT_APP_DELIVERY_APPROVAL_API_KEY=$REACT_APP_DELIVERY_APPROVAL_API_KEY
ENV REACT_APP_FORCE_LOBBY_DELIVERY_RESPONSE=$REACT_APP_FORCE_LOBBY_DELIVERY_RESPONSE
ENV REACT_APP_AVATAR_MODEL_VERSION=$REACT_APP_AVATAR_MODEL_VERSION
ENV REACT_APP_VISITOR_SEARCH_URL=$REACT_APP_VISITOR_SEARCH_URL
ENV REACT_APP_VR_IMAGE_UPLOAD_URL=$REACT_APP_VR_IMAGE_UPLOAD_URL
ENV REACT_APP_KIOSK_GATE_PROXY=$REACT_APP_KIOSK_GATE_PROXY
ENV REACT_APP_COMPACT_SYSTEM=$REACT_APP_COMPACT_SYSTEM
ENV REACT_APP_KIOSK_LOCAL_SPEECH=$REACT_APP_KIOSK_LOCAL_SPEECH
ENV REACT_APP_DETERMINISTIC_LOCAL_PROMPTS=$REACT_APP_DETERMINISTIC_LOCAL_PROMPTS
ENV REACT_APP_PHOTO_CAPTURE_MODE=$REACT_APP_PHOTO_CAPTURE_MODE
ENV REACT_APP_PHOTO_FACE_DETECT=$REACT_APP_PHOTO_FACE_DETECT

RUN npm run build

FROM nginx:1.27-alpine AS runtime

COPY deploy/frontend.nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/build /usr/share/nginx/html

EXPOSE 80
