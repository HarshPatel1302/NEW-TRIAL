REACT_APP_GEMINI_API_KEY=your_gemini_api_key_here
REACT_APP_RECEPTIONIST_API_URL=http://localhost:5000/api
REACT_APP_RECEPTIONIST_API_KEY=change_this_key
REACT_APP_KIOSK_ID=greenscape-lobby-kiosk-1
REACT_APP_ENABLE_CAMERA_PERSON_DETECTION=false

# External gate APIs (base URLs and fallback login credentials)
REACT_APP_GATE_API_BASE_URL=https://stggateapi.cubeone.in
REACT_APP_GATE_LOGIN_API_URL=https://societybackend.cubeone.in/api/login
REACT_APP_GATE_LOGIN_USERNAME=your_gate_login_username
REACT_APP_GATE_LOGIN_PASSWORD=your_gate_login_password
REACT_APP_WALKIN_COMPANY_ID=8196
REACT_APP_MEMBER_LIST_API_URL=https://socbackend.cubeone.in/api/admin/member/list
REACT_APP_VISITOR_LOG_API_URL=https://stggateapi.cubeone.in/api/visitor/log
REACT_APP_VISITOR_NOTIFICATION_API_URL=https://stggateapi.cubeone.in/api/visitor/sendFcmNotification
REACT_APP_VISITOR_LOG_COMPANY_NAME=Greenscape Group
REACT_APP_VISITOR_LOG_IN_GATE=MAIN GATE
REACT_APP_VISITOR_PURPOSE_CATEGORY_ID=1
REACT_APP_DELIVERY_PURPOSE_CATEGORY_ID=3
REACT_APP_VISITOR_LOG_CARD_ID=1

# Delivery approval webhook/API (optional for now; when absent flow falls back to lobby_drop guidance)
REACT_APP_DELIVERY_APPROVAL_API_URL=
REACT_APP_DELIVERY_APPROVAL_API_KEY=

# Avatar pipeline mode
# legacy = existing Gemini streamed-audio avatar (current default, preserves existing flow)
# local  = self-hosted avatar speech package via Python backend (text -> local TTS + Rhubarb cues)
REACT_APP_AVATAR_PIPELINE_MODE=legacy
REACT_APP_AVATAR_BACKEND_URL=http://localhost:8001
REACT_APP_AVATAR_MODEL_PATH=/models/receptionist/receptionist_all_6_actions_v2.glb
REACT_APP_AVATAR_RENDER_ADAPTER=three_d
