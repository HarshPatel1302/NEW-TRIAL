# Copy to `.env.local` for development. Never commit `.env.local`.
# Production: pass these as Docker build-args / CI secrets (see `.env.production.example` at repo root).

REACT_APP_GEMINI_API_KEY=
REACT_APP_RECEPTIONIST_API_URL=http://localhost:5050/api
REACT_APP_RECEPTIONIST_API_KEY=change_this_key
REACT_APP_KIOSK_ID=greenscape-lobby-kiosk-1

# External gate / society APIs (optional — leave empty to disable those integrations)
# Browser calls require CORS on the gate host, or proxy via your own backend.
REACT_APP_GATE_API_BASE_URL=
REACT_APP_GATE_LOGIN_API_URL=
REACT_APP_GATE_LOGIN_USERNAME=
REACT_APP_GATE_LOGIN_PASSWORD=
REACT_APP_WALKIN_COMPANY_ID=
REACT_APP_MEMBER_LIST_API_URL=
REACT_APP_VISITOR_LOG_API_URL=
REACT_APP_VISITOR_NOTIFICATION_API_URL=
REACT_APP_VISITOR_LOG_COMPANY_NAME=Greenscape Group
REACT_APP_VISITOR_LOG_IN_GATE=MAIN GATE
REACT_APP_VISITOR_PURPOSE_CATEGORY_ID=1
REACT_APP_DELIVERY_PURPOSE_CATEGORY_ID=3
REACT_APP_VISITOR_LOG_CARD_ID=1

# Optional: override GET visitor search URL (defaults to {GATE}/api/visitor/entry?...).
# Use for mocks, e.g. https://your-mock.example/api/search
# REACT_APP_VISITOR_SEARCH_URL=

# Preferred alias set (mapped internally to the same integrations)
REACT_APP_VR_LOGIN_URL=
REACT_APP_VR_VISITOR_SEARCH_URL=
REACT_APP_VR_VISITOR_CREATE_URL=
REACT_APP_VR_MEMBER_LIST_URL=
REACT_APP_VR_VISITOR_LOG_URL=
REACT_APP_VR_SEND_FCM_URL=
REACT_APP_VR_IMAGE_UPLOAD_URL=
REACT_APP_VR_COMPANY_ID=8196
REACT_APP_VR_COMPANY_NAME=cyberone
REACT_APP_VR_IN_GATE=cyberone lobby
REACT_APP_VR_LOGIN_USERNAME=
REACT_APP_VR_LOGIN_PASSWORD=

# Delivery approval webhook (optional; when absent, flow uses lobby guidance)
REACT_APP_DELIVERY_APPROVAL_API_URL=
REACT_APP_DELIVERY_APPROVAL_API_KEY=
# Set to "false" only if your delivery API returns real allow/decline decisions
# REACT_APP_FORCE_LOBBY_DELIVERY_RESPONSE=true
