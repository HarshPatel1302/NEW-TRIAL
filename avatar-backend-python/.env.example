AVATAR_BACKEND_HOST=0.0.0.0
AVATAR_BACKEND_PORT=8001
AVATAR_BACKEND_CORS_ORIGINS=http://localhost:3000
AVATAR_BACKEND_MEDIA_DIR=./storage/media
AVATAR_BACKEND_TEMP_DIR=./storage/temp
AVATAR_BACKEND_CACHE_ENABLED=true
AVATAR_BACKEND_DEFAULT_EXPRESSION=friendly
AVATAR_BACKEND_DEFAULT_ANIMATION=speaking

# TTS provider: piper | dummy
AVATAR_BACKEND_TTS_PROVIDER=piper
AVATAR_BACKEND_PIPER_BINARY=piper
AVATAR_BACKEND_PIPER_MODEL=
AVATAR_BACKEND_PIPER_CONFIG=
AVATAR_BACKEND_PIPER_SPEAKER_ID=
AVATAR_BACKEND_DEFAULT_VOICE=

# Lip-sync provider: rhubarb | none
AVATAR_BACKEND_LIPSYNC_PROVIDER=rhubarb
AVATAR_BACKEND_RHUBARB_BINARY=rhubarb

# Optional Phase-2 render adapter foundation
AVATAR_BACKEND_RENDER_ADAPTER=three_d
