PORT=5000
# Comma-separated allowed origins, or omit to allow reflecting browser Origin (needed for trycloudflare.com URLs)
CORS_ORIGIN=http://localhost:3000
TRUST_PROXY=false
BACKEND_API_KEY=change_this_key

# CubeOne / society gate — used when frontend has REACT_APP_CUBEONE_VIA_BACKEND=1 (browser calls /api/integrations/cubeone/*)
GATE_LOGIN_API_URL=https://societybackend.cubeone.in/api/login
GATE_LOGIN_USERNAME=919998887772
GATE_LOGIN_PASSWORD=123456789
GATE_API_BASE_URL=https://stggateapi.cubeone.in
MEMBER_LIST_API_URL=https://socbackend.cubeone.in/api/admin/member/list
WALKIN_COMPANY_ID=8196
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600
RETENTION_DAYS=180
BACKUP_DIR=./backups
VISITOR_PHOTO_STORAGE_DIR=./storage/visitor-photos

# Cloud cover upload (used for visitor image sync)
COVER_UPLOAD_API_URL=https://meetservice.cubeone.in/api/v1/upload-cover

# Option A: use a single URL
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/receptionist

# Option B: use individual fields
PGHOST=localhost
PGPORT=55432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=receptionist

# Set true only if your hosted Postgres requires SSL
PGSSL=false
