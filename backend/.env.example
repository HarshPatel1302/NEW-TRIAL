# Default 5050: on macOS, port 5000 is frequently bound by Control Center (AirPlay).
PORT=5050
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
TRUST_PROXY=false
BACKEND_API_KEY=change_this_key
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600
RETENTION_DAYS=180
BACKUP_DIR=./backups
VISITOR_PHOTO_STORAGE_DIR=./storage/visitor-photos

# Cloud cover upload (visitor image sync). Set in production; do not commit real URLs.
# COVER_UPLOAD_API_URL=
# Optional fallbacks (same as gate login on frontend if you use one identity provider):
# COVER_UPLOAD_LOGIN_URL=
# COVER_UPLOAD_USERNAME=
# COVER_UPLOAD_PASSWORD=

# Option A: use a single URL
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/receptionist

# Option B: use individual fields
PGHOST=localhost
PGPORT=55432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=receptionist

# Set true only if your hosted Postgres requires SSL
PGSSL=false
