# Default 5050: on macOS, port 5000 is frequently bound by Control Center (AirPlay).
PORT=5050
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
TRUST_PROXY=false
BACKEND_API_KEY=change_this_key
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600

# CLI: log every API request/response (redacted bodies; photo/data URLs → lengths only).
# unset in non-production → summary | 0|false|off → disabled | 1|on → summary | verbose|2 → full redacted JSON
# BACKEND_HTTP_LOG=1
RETENTION_DAYS=180
BACKUP_DIR=./backups
VISITOR_PHOTO_STORAGE_DIR=./storage/visitor-photos

# Cloud cover upload (visitor image sync). Default upstream: meetservice CubeOne upload-cover.
# COVER_UPLOAD_API_URL=https://meetservice.cubeone.in/api/v1/upload-cover
#
# Auth (pick one):
# A) Server-only Bearer for Keycloak/meetservice (recommended — never put this in React):
# COVER_UPLOAD_BEARER_TOKEN=
#
# B) Username/password login (societybackend-style) before upload:
# COVER_UPLOAD_LOGIN_URL=
# COVER_UPLOAD_USERNAME=
# COVER_UPLOAD_PASSWORD=

# Option A: use a single URL
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/receptionist

# Option B: use individual fields
PGHOST=localhost
PGPORT=55432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=receptionist

# Set true only if your hosted Postgres requires SSL
PGSSL=false

# --- Optional: kiosk gate proxy (one server-side token + visitor search + member index) ---
# When enabled, set REACT_APP_KIOSK_GATE_PROXY=1 on the frontend and mirror these with your gate credentials.
#
# Required to turn the proxy on (truthy: 1, true, yes, on — case-insensitive):
#   KIOSK_GATE_PROXY_ENABLED=1
#
# Required for token + visitor search (warmup exercises login):
#   KIOSK_GATE_LOGIN_URL=   (or REACT_APP_GATE_LOGIN_API_URL in same env file)
#   KIOSK_GATE_USERNAME=
#   KIOSK_GATE_PASSWORD=
#
# Recommended for default visitor search URL building:
#   KIOSK_GATE_BASE_URL=    (gate API origin; or set KIOSK_VISITOR_SEARCH_URL override)
#   KIOSK_GATE_COMPANY_ID=8196
#
# Optional member directory (warmup prefetches index when URL set):
#   KIOSK_MEMBER_LIST_URL=  (or REACT_APP_MEMBER_LIST_API_URL)
#
# Optional visitor search override (full URL template):
#   KIOSK_VISITOR_SEARCH_URL=
#
# Diagnostics (no API key required): GET /api/kiosk/proxy-status
# Warmup (structured JSON, always HTTP 200): POST /api/kiosk/warmup
# Also: POST /api/kiosk/visitor-search, /api/kiosk/batch-lookup,
# /api/kiosk/member-search, /api/kiosk/company-search, /api/kiosk/recipient-search.
# batch-lookup: when member_primary/query is non-empty, visitor lookup is skipped by default;
# pass include_visitor=true (or skip_visitor=false) to run both legs.
